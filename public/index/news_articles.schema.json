{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hanshi.kr/schemas/news_articles.schema.json",
  "title": "Hanshi News Articles",
  "type": "object",
  "required": ["version", "lastUpdated", "articles"],
  "properties": {
    "version": {
      "type": "string",
      "description": "뉴스 데이터 스키마 버전"
    },
    "lastUpdated": {
      "type": "string",
      "format": "date-time"
    },
    "articles": {
      "type": "array",
      "maxItems": 50,
      "items": {
        "type": "object",
        "required": [
          "id",
          "category",
          "articleType",
          "title",
          "body",
          "source",
          "sourceUrl",
          "publishedAt",
          "crawledAt",
          "keywords"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "articleType": {
            "type": "string",
            "enum": ["news", "info", "column"],
            "description": "일반 기사(news), 단순 안내성 정보(info), 칼럼(column)"
          },
          "title": { "type": "string", "minLength": 1 },
          "summary": { "type": "string", "maxLength": 180 },
          "body": {
            "type": "string",
            "minLength": 20,
            "maxLength": 500,
            "description": "정보성 기사 목표 길이 300~500자. 칼럼은 안내문 형태로 최소 20자 허용."
          },
          "source": { "type": "string", "minLength": 1 },
          "sourceUrl": { "type": "string", "format": "uri" },
          "publishedAt": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "crawledAt": { "type": "string", "format": "date-time" },
          "aiWritten": {
            "type": "boolean",
            "description": "LLM 재작성이 적용된 기사면 true"
          },
          "keywords": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "imageUrl": { "type": "string", "format": "uri" },
          "columnAuthor": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
