  <script is:inline src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
  <script is:inline src="/shared/supabase.js"></script>
  <script is:inline src="/shared/auth-state.js"></script>
  <script is:inline src="/shared/board/core.js"></script>
  <script is:inline src="/shared/board/feed.js"></script>
  <script is:inline src="/shared/board/showcase.js"></script>
  <script is:inline src="/shared/board/write.js"></script>
  <script is:inline src="/shared/board/comments.js"></script>
  <script is:inline src="/shared/board/ai-bg.js"></script>
  <script is:inline src="/shared/board/handlers.js"></script>
