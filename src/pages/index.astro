---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="홈" description="한시의 모든 것 — 한시나루">
  <main style="padding-top: var(--nav-height); min-height: 100vh; display: flex; align-items: center; justify-content: center;">
    <div style="text-align: center; max-width: 600px; padding: 40px;">
      <h1 style="font-size: var(--fs-display); font-family: var(--font-zh); margin-bottom: 16px;">漢詩나루</h1>
      <p style="font-size: var(--fs-lead); color: var(--c-muted); line-height: 1.6;">
        Astro 전환 진행 중입니다.<br />
        기존 사이트는 정상 운영됩니다.
      </p>
      <p style="margin-top: 24px; font-size: var(--fs-small); color: var(--c-faint);">
        Phase 1 — 프로젝트 초기화 완료
      </p>
    </div>
  </main>
</BaseLayout>
