---
/**
 * 준비 중 플레이스홀더 페이지
 * 아직 콘텐츠가 없는 메뉴 항목에 사용
 */
import SidebarLayout from '../layouts/SidebarLayout.astro';

// URL에서 section 추론
const path = Astro.url.pathname;
const section = path.startsWith('/hansi') ? 'hansi'
  : path.startsWith('/hanja') ? 'hanja'
  : path.startsWith('/community') ? 'community'
  : 'writing-helper';

// 메뉴 라벨 매핑
const labels: Record<string, string> = {
  '/hansi/chinese/poets/': '대표작가와 작품소개',
  '/hansi/chinese/reading/': '중국 한시 읽기',
  '/hansi/korean/poets/': '대표작가와 작품소개',
  '/hansi/korean/reading/': '한국 한시 읽기',
  '/hanja/app/': '한자한자 앱소개',
  '/writing-helper/': '한시 도우미',
};

const title = labels[path] || '준비 중';
---

<SidebarLayout title={title} section={section}>
  <div class="coming-soon">
    <div class="coming-soon-icon">&#9997;</div>
    <h1>{title}</h1>
    <p>콘텐츠를 준비하고 있습니다.</p>
    <p class="coming-soon-sub">빠른 시일 내에 찾아뵙겠습니다.</p>
  </div>
</SidebarLayout>

<style>
  .coming-soon {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 400px;
    text-align: center;
    color: var(--c-muted);
  }
  .coming-soon-icon {
    font-size: 48px;
    margin-bottom: 16px;
    opacity: 0.3;
  }
  .coming-soon h1 {
    font-size: var(--fs-h2);
    margin-bottom: 12px;
    color: var(--c-ink);
  }
  .coming-soon p {
    font-size: var(--fs-body);
    line-height: 1.6;
  }
  .coming-soon-sub {
    margin-top: 8px;
    font-size: var(--fs-small);
    color: var(--c-faint);
  }
</style>
