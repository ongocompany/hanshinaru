---
import SidebarLayout from '../../../../layouts/SidebarLayout.astro';
import { getErasByCountry, type Era } from '../../../../data/eras';

// 정적 prerender (운영 jinas에 SSR Node 미설치 — 시대 데이터는 정적이므로 prerender)
export const prerender = true;
export function getStaticPaths() {
  return getErasByCountry('CN').map((era) => ({
    params: { slug: era.slug },
    props: { era },
  }));
}

interface Props {
  era: Era;
}
const { era } = Astro.props;
---

<SidebarLayout title={`${era.name_ko}(${era.name_zh}) — 중국 한시`} section="hansi">
  <article class="era-page">
    <header class="era-header">
      <h1 class="era-title">
        <span class="era-name-ko">{era.name_ko}</span>
        <span class="era-name-zh">({era.name_zh})</span>
      </h1>
      <p class="era-period">{era.period}</p>
    </header>

    <section class="era-section">
      <h2>시대 배경</h2>
      <p class="placeholder">콘텐츠를 준비하고 있습니다.</p>
    </section>

    <section class="era-section">
      <h2>한시의 특징</h2>
      <p class="placeholder">콘텐츠를 준비하고 있습니다.</p>
    </section>

    <section class="era-section">
      <h2>대표 시인</h2>
      <p class="placeholder">데이터 연동 준비 중.</p>
    </section>

    <section class="era-section">
      <h2>대표 작품</h2>
      <p class="placeholder">데이터 연동 준비 중.</p>
    </section>

    <a href={`/hansi/chinese/reading/?era=${era.slug}`} class="era-cta">
      → {era.name_ko} 한시 전체 보기
    </a>
  </article>
</SidebarLayout>

<style>
  .era-page {
    max-width: 760px;
    margin: 0 auto;
  }

  .era-header {
    border-bottom: 1px solid var(--c-border);
    padding-bottom: 16px;
    margin-bottom: 32px;
  }

  .era-title {
    font-size: var(--fs-h1);
    margin: 0 0 8px;
    color: var(--c-ink);
    font-weight: 600;
  }

  .era-name-zh {
    font-family: 'Noto Serif SC', serif;
    color: var(--c-muted);
    margin-left: 6px;
  }

  .era-period {
    color: var(--c-muted);
    font-size: var(--fs-small);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .era-section {
    margin-bottom: 32px;
  }

  .era-section h2 {
    font-size: var(--fs-h3);
    color: var(--c-ink);
    margin-bottom: 12px;
    font-weight: 600;
  }

  .placeholder {
    color: var(--c-muted);
    font-style: italic;
    line-height: 1.7;
  }

  .era-cta {
    display: inline-block;
    margin-top: 24px;
    padding: 12px 20px;
    border: 1px solid var(--c-border);
    color: var(--c-ink);
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .era-cta:hover {
    background: var(--c-silver, #f5f5f5);
  }
</style>
