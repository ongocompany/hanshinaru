<style>
  .footer {
    border-top: 1px solid var(--c-border);
    padding: 48px 24px;
    text-align: center;
    color: var(--c-faint);
    font-size: var(--fs-small);
    line-height: 1.6;
  }

  .footer-inner {
    max-width: 600px;
    margin: 0 auto;
  }

  .footer-brand {
    font-size: var(--fs-h3);
    color: var(--c-slate-grey);
    margin-bottom: 8px;
  }

  .footer-desc { margin-bottom: 4px; }
  .footer-source { margin-bottom: 16px; }

  .footer-links, .footer-legal {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .footer-links a, .footer-legal a {
    color: var(--c-muted);
    text-decoration: none;
  }
  .footer-links a:hover, .footer-legal a:hover {
    text-decoration: underline;
  }

  .footer-links::after {
    content: '';
    display: block;
    width: 100%;
    height: 0;
  }

  .footer-legal {
    margin-top: 8px;
    font-size: 12px;
  }

  .footer-links a + a::before,
  .footer-legal a + a::before {
    content: '·';
    margin-right: 8px;
    color: var(--c-faint);
  }
</style>
