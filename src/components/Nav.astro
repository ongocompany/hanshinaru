---
import navigation from '../data/navigation.json';

interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;
const topMenu = navigation.topMenu;
---

<nav class="nav" id="topNav">
  <div class="nav-inner">
    <a href="/" class="nav-brand zh">한시나루</a>

    <button class="nav-hamburger" id="navHamburger" aria-label="메뉴" aria-expanded="false">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
    </button>

    <div class="nav-links" id="navLinks">
      {topMenu.map((item) => (
        item.children ? (
          <div class="nav-dropdown">
            <a
              href={item.path}
              class:list={['nav-link', 'has-dropdown', { active: currentPath.startsWith(`/${item.id}`) }]}
            >
              {item.label} <span class="dropdown-arrow">&#9662;</span>
            </a>
            <div class="dropdown-panel">
              {item.children.map((child) => (
                <a href={child.path} class:list={{ active: currentPath === child.path }}>
                  {child.label}
                </a>
              ))}
            </div>
          </div>
        ) : (
          <a
            href={item.path}
            class:list={['nav-link', { active: currentPath.startsWith(`/${item.id}`), disabled: item.disabled }]}
          >
            {item.label}
          </a>
        )
      ))}

      <div class="nav-search-wrap">
        <button class="nav-search-btn" aria-label="검색" type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: var(--nav-height);
    background: #1a1a1a;
    color: #fff;
    z-index: 1000;
    display: flex;
    align-items: center;
  }

  .nav-inner {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .nav-brand {
    font-size: 20px;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    margin-right: 32px;
    white-space: nowrap;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    flex: 1;
  }

  .nav-link {
    color: #ccc;
    text-decoration: none;
    padding: 8px 14px;
    font-size: var(--fs-small);
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    white-space: nowrap;
  }
  .nav-link:hover { color: #fff; background: rgba(255,255,255,0.08); text-decoration: none; }
  .nav-link.active { color: #fff; }
  .nav-link.disabled { opacity: 0.4; pointer-events: none; }

  .dropdown-arrow { font-size: 10px; margin-left: 2px; }

  /* Dropdown */
  .nav-dropdown { position: relative; }
  .dropdown-panel {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #2a2a2a;
    border-radius: 8px;
    padding: 8px 0;
    min-width: 200px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.3);
  }
  .nav-dropdown:hover .dropdown-panel { display: block; }
  .dropdown-panel a {
    display: block;
    padding: 8px 20px;
    color: #ccc;
    font-size: var(--fs-small);
    text-decoration: none;
    transition: background 0.12s;
  }
  .dropdown-panel a:hover { background: rgba(255,255,255,0.08); color: #fff; }
  .dropdown-panel a.active { color: var(--c-powder-blue); }

  /* Search */
  .nav-search-wrap { margin-left: auto; }
  .nav-search-btn {
    background: none; border: none; color: #ccc; cursor: pointer;
    padding: 8px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }
  .nav-search-btn:hover { color: #fff; background: rgba(255,255,255,0.08); }

  /* Hamburger */
  .nav-hamburger {
    display: none;
    background: none; border: none; color: #fff; cursor: pointer;
    padding: 8px;
    margin-left: auto;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .nav-hamburger { display: block; }
    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0; right: 0;
      background: #1a1a1a;
      flex-direction: column;
      padding: 16px;
      gap: 0;
      border-top: 1px solid #333;
    }
    .nav-links.open { display: flex; }
    .nav-link { padding: 12px 16px; width: 100%; }
    .nav-dropdown { width: 100%; }
    .dropdown-panel {
      position: static;
      display: none;
      box-shadow: none;
      background: #222;
      border-radius: 0;
      padding-left: 16px;
    }
    .nav-dropdown.open .dropdown-panel { display: block; }
    .nav-search-wrap { margin-left: 0; width: 100%; }
  }
</style>

<script>
  const hamburger = document.getElementById('navHamburger');
  const links = document.getElementById('navLinks');

  hamburger?.addEventListener('click', () => {
    const open = links?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(!!open));
  });

  // Mobile: dropdown toggle on click
  document.querySelectorAll('.nav-dropdown > .nav-link').forEach(link => {
    link.addEventListener('click', (e) => {
      if (window.innerWidth <= 768) {
        e.preventDefault();
        link.closest('.nav-dropdown')?.classList.toggle('open');
      }
    });
  });
</script>
