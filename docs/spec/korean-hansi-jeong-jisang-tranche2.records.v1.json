      "entryTitle": "冊王太子御宴致語",
      "sourceUrl": "https://zh.wikisource.org/wiki/%E6%9D%B1%E6%96%87%E9%81%B8/%E5%8D%B7%E4%B8%80%E7%99%BE%E5%9B%9B",
      "sourcePolicyId": "SRC-WIKISOURCE-TEXT"
