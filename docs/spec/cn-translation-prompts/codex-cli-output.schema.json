{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["title_ko", "translation", "reading", "commentary", "notes"],
  "properties": {
    "title_ko": {
      "type": "string",
      "minLength": 1
    },
    "translation": {
      "type": "string",
      "minLength": 1
    },
    "reading": {
      "type": "string",
      "minLength": 1
    },
    "commentary": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["word", "meaning"],
        "properties": {
          "word": {
            "type": "string",
            "minLength": 1
          },
          "meaning": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
