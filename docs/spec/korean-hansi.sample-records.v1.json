    "title": {
      "zh": "別小宛",
      "ko": "소완과 이별하며"
    },
    "author": {
      "authorId": "KAUTH-HN-0001",
      "zh": "許蘭雪軒",
      "ko": "허난설헌"
    },
    "era": {
