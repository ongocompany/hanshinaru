---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getBookBySlug, getAnnotationsByVolume } from '../../../../lib/db';

const { slug, n } = Astro.params;

if (!slug || typeof slug !== 'string' || !n) {
  return new Response('Not Found', { status: 404 });
}

const num = Number(n);
if (!Number.isInteger(num) || num <= 0 || num > 999) {
  return new Response('Not Found', { status: 404 });
}

const book = await getBookBySlug(slug);
if (!book) {
  return new Response('Not Found', { status: 404 });
}

const NUM_HANJA = ['', '一', '二', '三', '四', '五', '六', '七', '八', '九', '十'];
const juan = `卷${NUM_HANJA[num] ?? num}`;

const items = await getAnnotationsByVolume(book.id, juan);

if (items.length === 0) {
  return new Response('Not Found', { status: 404 });
}

const groupedByCategory = new Map<string, typeof items>();
for (const it of items) {
  const cat = it.category ?? '미분류';
  if (!groupedByCategory.has(cat)) groupedByCategory.set(cat, []);
  groupedByCategory.get(cat)!.push(it);
}

function poemHref(it: { poem_id: number | null; position: string }): string {
  return it.poem_id ? `/poems/${it.poem_id}` : `/books/${slug}/poems/${it.position}`;
}
---

<BaseLayout title={`${juan} — ${book.title_ko ?? book.title_zh}`} description={`《${book.title_zh}》${juan}의 시 목록`}>
  <main class="volume-page">
    <header class="page-header">
      <p class="breadcrumb">
        <a href="/books">서적</a> ·
        <a href={`/books/${book.slug}`}>{book.title_zh}</a> ·
        <a href={`/books/${book.slug}/volumes`}>권별</a>
      </p>
      <h1 class="juan-title">{juan}</h1>
      <p class="lead">총 {items.length}수</p>
    </header>

    {Array.from(groupedByCategory.entries()).map(([cat, list]) => (
      <section class="category-block">
        <h2 class="category-title">{cat} <span class="cat-count">({list.length}수)</span></h2>
        <ul class="poem-list">
          {list.map((it) => (
            <li class="poem-item">
              <a href={poemHref(it)} class="poem-link">
                <span class="position">{it.position}</span>
                <span class="title-zh">{it.title_zh}</span>
                {it.title_ko && <span class="title-ko">{it.title_ko}</span>}
                {it.poet_name_zh && (
                  <span class="poet-name">{it.poet_name_zh}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</BaseLayout>

<style>
  .volume-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px 96px;
  }

  .breadcrumb {
    color: #9ca3af;
    font-size: 0.9rem;
    margin: 0 0 8px;
  }

  .breadcrumb a {
    color: #6b7280;
    text-decoration: none;
    border-bottom: 1px dashed #9ca3af;
  }

  .breadcrumb a:hover { color: #111827; }

  .page-header {
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid #e5e7eb;
  }

  .juan-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 2.5rem;
    font-weight: 700;
    margin: 0 0 6px;
  }

  .lead {
    color: #6b7280;
    margin: 0;
  }

  .category-block {
    margin-bottom: 32px;
  }

  .category-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: #1f2937;
    margin: 0 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid #e5e7eb;
  }

  .cat-count {
    color: #9ca3af;
    font-size: 0.85rem;
    font-weight: 400;
  }

  .poem-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .poem-item {
    border-bottom: 1px solid #f3f4f6;
  }

  .poem-link {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 10px 8px;
    color: inherit;
    text-decoration: none;
    transition: background 0.15s;
  }

  .poem-link:hover {
    background: #f9fafb;
  }

  .position {
    font-family: ui-monospace, monospace;
    color: #9ca3af;
    font-size: 0.8rem;
    min-width: 36px;
  }

  .title-zh {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.05rem;
    font-weight: 500;
  }

  .title-ko {
    color: #6b7280;
    font-size: 0.9rem;
  }

  .poet-name {
    margin-left: auto;
    font-family: 'Noto Serif SC', serif;
    color: #4b5563;
    font-size: 0.9rem;
  }
</style>
